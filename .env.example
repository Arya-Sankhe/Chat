PLAN_HOBBY_MAX_DOCUMENT_PAGES=50
PLAN_HOBBY_DAILY_DOCUMENT_TOOL_CALLS=25
PLAN_HOBBY_DAILY_GENERATED_DOCUMENTS=5

PLAN_PRO_PRICE_LABEL=
PLAN_PRO_DAILY_MESSAGES=600
PLAN_PRO_MONTHLY_IMAGES=1000
PLAN_PRO_MAX_IMAGES_PER_MESSAGE=4
PLAN_PRO_MAX_DOCUMENTS_PER_MESSAGE=5
PLAN_PRO_MAX_DOCUMENT_BYTES_PER_MESSAGE=62914560
PLAN_PRO_MAX_DOCUMENT_PAGES=100
PLAN_PRO_DAILY_DOCUMENT_TOOL_CALLS=100
PLAN_PRO_DAILY_GENERATED_DOCUMENTS=20

PLAN_INTERMEDIATE_PRICE_LABEL=
PLAN_INTERMEDIATE_DAILY_MESSAGES=1500
PLAN_INTERMEDIATE_MONTHLY_IMAGES=2500
PLAN_INTERMEDIATE_MAX_IMAGES_PER_MESSAGE=4
PLAN_INTERMEDIATE_MAX_DOCUMENTS_PER_MESSAGE=5
