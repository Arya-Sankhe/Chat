# ─── Web search ────────────────────────────────────────────────────
# Primary: Jina Search Foundation (s.jina.ai) — one call returns search
# results + extracted page content for the top N URLs. JINA_API_KEY is
# REQUIRED for s.jina.ai (search). New keys include a 10M-token free
# trial, then pay-as-you-go. The reader endpoint r.jina.ai used by the
# `read_url` tool still works anonymously at ~20 RPM if no key is set.
JINA_API_KEY=
JINA_SEARCH_PROVIDER=google         # google | bing
JINA_SEARCH_ENGINE=direct           # direct (fast) | browser (JS-rendered)

# Fallback: Brave LLM Context API. $5/1k requests, $5/mo free credit.
BRAVE_SEARCH_API_KEY=

# Toggle behaviour. Users can still flip Auto/Off in the UI; this is the
# server-wide default for new users + sessions.
WEBSEARCH_DEFAULT_MODE=auto         # auto | off
WEBSEARCH_PRIMARY_PROVIDER=jina     # jina | brave
WEBSEARCH_MAX_RESULTS=5
WEBSEARCH_PAGE_CONTENT_CHARS=4000
WEBSEARCH_TOTAL_CONTEXT_CHARS=12000
WEBSEARCH_CACHE_TTL_SECONDS=900
WEBSEARCH_CACHE_MAX_ENTRIES=500
WEBSEARCH_FETCH_TIMEOUT_MS=8000
WEBSEARCH_MAX_TOOL_CALLS_PER_TURN=3
WEBSEARCH_DENY_DOMAINS=

# Per-plan daily search quotas. Zero disables web search for that plan.
WEBSEARCH_DAILY_LIMIT_HOBBY=50
WEBSEARCH_DAILY_LIMIT_PRO=200
WEBSEARCH_DAILY_LIMIT_INTERMEDIATE=500
WEBSEARCH_DAILY_LIMIT_SCALE=2000
WEBSEARCH_DAILY_LIMIT_MAX=5000
