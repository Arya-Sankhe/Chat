APP_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0

# Server-only managed model provider key. Never expose this to the browser.
CROFAI_API_KEY=
CROFAI_BASE_URL=https://crof.ai/v1

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_GOOGLE_ENABLED=false

# Access
# testing: every signed-in user gets TEST_PLAN_ID without a payment gateway.
# subscription: only users with an active row in subscriptions can chat.
ACCESS_MODE=testing
TEST_PLAN_ID=pro

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_UPLOAD_EXPIRES_SECONDS=300
R2_READ_EXPIRES_SECONDS=900
R2_MAX_IMAGE_BYTES=6291456

PLAN_HOBBY_PRICE_LABEL=
PLAN_HOBBY_DAILY_MESSAGES=150
PLAN_HOBBY_MONTHLY_IMAGES=200
PLAN_HOBBY_MAX_IMAGES_PER_MESSAGE=4

PLAN_PRO_PRICE_LABEL=
PLAN_PRO_DAILY_MESSAGES=600
PLAN_PRO_MONTHLY_IMAGES=1000
PLAN_PRO_MAX_IMAGES_PER_MESSAGE=4

PLAN_INTERMEDIATE_PRICE_LABEL=
PLAN_INTERMEDIATE_DAILY_MESSAGES=1500
PLAN_INTERMEDIATE_MONTHLY_IMAGES=2500
PLAN_INTERMEDIATE_MAX_IMAGES_PER_MESSAGE=4

PLAN_SCALE_PRICE_LABEL=
PLAN_SCALE_DAILY_MESSAGES=5000
PLAN_SCALE_MONTHLY_IMAGES=7500
PLAN_SCALE_MAX_IMAGES_PER_MESSAGE=6

PLAN_MAX_PRICE_LABEL=
PLAN_MAX_DAILY_MESSAGES=15000
PLAN_MAX_MONTHLY_IMAGES=20000
PLAN_MAX_MAX_IMAGES_PER_MESSAGE=8
