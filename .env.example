APP_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0

# Additional comma-separated origins for local Capacitor development.
# Production defaults already include https://klui.tech, https://www.klui.tech,
# and the packaged Android origin https://localhost.
MOBILE_ALLOWED_ORIGINS=

CROFAI_API_KEY=
CROFAI_BASE_URL=https://crof.ai/v1

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=

# Access
# testing: every signed-in user gets TEST_PLAN_ID for local/MVP testing.
# subscription: only users with an active approved subscription can chat.
ACCESS_MODE=testing
TEST_PLAN_ID=essential

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_UPLOAD_EXPIRES_SECONDS=300
R2_READ_EXPIRES_SECONDS=900
R2_MAX_IMAGE_BYTES=10485760

# Daily VPS cleanup for uploaded files that were never attached to a chat.
STORAGE_CLEANUP_GRACE_DAYS=7
STORAGE_CLEANUP_BATCH_SIZE=100

# ─── Conversation context ──────────────────────────────────────────
# Compact older turns at ~140k estimated tokens, keep the recent 80k
# verbatim, and reserve 32k for the current response and tool context.
CONTEXT_MAX_TOKENS=256000
CONTEXT_COMPACT_AT_TOKENS=140000
CONTEXT_KEEP_RECENT_TOKENS=80000
CONTEXT_RESERVE_TOKENS=32000
CONTEXT_SUMMARY_MODEL=deepseek/deepseek-v4-flash
CONTEXT_SUMMARY_MAX_TOKENS=2000

# ─── Document tools ────────────────────────────────────────────────
DOCUMENTS_ENABLED=true
DOCUMENT_MAX_FILE_BYTES=31457280
DOCUMENT_MAX_FILES_PER_MESSAGE=5
DOCUMENT_MAX_TOTAL_BYTES_PER_MESSAGE=62914560
DOCUMENT_MAX_PDF_PAGES=100
DOCUMENT_MAX_DOCX_WORDS=80000
DOCUMENT_MAX_XLSX_SHEETS=25
DOCUMENT_MAX_XLSX_CELLS=250000
DOCUMENT_MAX_CSV_ROWS=100000
DOCUMENT_MAX_CSV_COLUMNS=100
DOCUMENT_MAX_EXTRACTED_CHARS=500000
DOCUMENT_CONTEXT_CHARS_PER_TURN=20000

# Project knowledge capacity (source file bytes, per project)
PLAN_LITE_MAX_PROJECT_BYTES=52428800
PLAN_ESSENTIAL_MAX_PROJECT_BYTES=104857600
PLAN_PRO_MAX_PROJECT_BYTES=157286400
DOCUMENT_MAX_TOOL_RESULT_CHARS=24000
DOCUMENT_MAX_TOOL_CALLS_PER_TURN=75
DOCUMENT_VISUAL_EMBED_MODEL=jina-embeddings-v5-omni-nano
DOCUMENT_VISUAL_PAGE_DPI=144
DOCUMENT_VISUAL_MAX_PAGES_PER_TOOL=40
DOCUMENT_VISUAL_MAX_IMAGE_INPUTS_PER_TURN=24
DOCUMENT_VISUAL_INLINE_IMAGES=true
DOCUMENT_VISUAL_INLINE_MAX_BYTES=2097152
DOCUMENT_VISUAL_INLINE_MAX_TOTAL_BYTES=12582912
DOCUMENT_WORKER_CONCURRENCY=2
DOCUMENT_WORKER_POLL_SECONDS=0.5
DOCUMENT_WORKER_MEMORY_LIMIT=3g
DOCUMENT_JOB_TIMEOUT_MS=120000
DOCUMENT_LEASE_HEARTBEAT_SECONDS=30
DOCUMENT_HTTP_MAX_ATTEMPTS=3
DOCUMENT_PDF_RENDER_WORKERS=2
DOCUMENT_JINA_BATCH_SIZE=8
DOCUMENT_JINA_BATCH_CONCURRENCY=2
DOCUMENT_PAGE_UPLOAD_WORKERS=4
DOCUMENT_TOOL_JOB_WAIT_MS=20000
DOCUMENT_UPLOAD_EXPIRES_SECONDS=900
DOCUMENT_PREVIEW_MAX_PAGES=2
DOCUMENT_PREVIEW_TTL_DAYS=30

RESEARCH_WORKER_CONCURRENCY=3
RESEARCH_FETCH_CONCURRENCY=3

PLAN_LITE_PRICE_LABEL=10 AED / month
PLAN_LITE_AMOUNT_AED=10
PLAN_LITE_MONTHLY_API_CREDITS=2
PLAN_LITE_MAX_IMAGES_PER_MESSAGE=4
PLAN_LITE_MAX_DOCUMENTS_PER_MESSAGE=5
PLAN_LITE_MAX_DOCUMENT_BYTES_PER_MESSAGE=31457280
PLAN_LITE_MAX_DOCUMENT_PAGES=50
PLAN_LITE_ZIINA_PAYMENT_URL=
PLAN_LITE_ZIINA_QR_IMAGE_URL=

PLAN_ESSENTIAL_PRICE_LABEL=30 AED / month
PLAN_ESSENTIAL_AMOUNT_AED=30
PLAN_ESSENTIAL_MONTHLY_API_CREDITS=10
PLAN_ESSENTIAL_MAX_IMAGES_PER_MESSAGE=4
PLAN_ESSENTIAL_MAX_DOCUMENTS_PER_MESSAGE=5
PLAN_ESSENTIAL_MAX_DOCUMENT_BYTES_PER_MESSAGE=62914560
PLAN_ESSENTIAL_MAX_DOCUMENT_PAGES=100
PLAN_ESSENTIAL_ZIINA_PAYMENT_URL=
PLAN_ESSENTIAL_ZIINA_QR_IMAGE_URL=

PLAN_PRO_PRICE_LABEL=50 AED / month
PLAN_PRO_AMOUNT_AED=50
PLAN_PRO_MONTHLY_API_CREDITS=25
PLAN_PRO_MAX_IMAGES_PER_MESSAGE=4
PLAN_PRO_MAX_DOCUMENTS_PER_MESSAGE=5
PLAN_PRO_MAX_DOCUMENT_BYTES_PER_MESSAGE=62914560
PLAN_PRO_MAX_DOCUMENT_PAGES=100
PLAN_PRO_ZIINA_PAYMENT_URL=
PLAN_PRO_ZIINA_QR_IMAGE_URL=

# ─── Web search ────────────────────────────────────────────────────
# Primary: internal SearXNG SERP/snippet search. Deep page reads still use
# Jina Reader through read_url when the model needs exact page content.
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_ENGINES=duckduckgo,bing

# Fallback: Jina Search Foundation (s.jina.ai) — one call returns search
JINA_API_KEY=
JINA_SEARCH_ENGINE=direct           # direct (fast) | browser (JS-rendered)

# Fallback: Brave LLM Context API. $5/1k requests, $5/mo free credit.
BRAVE_SEARCH_API_KEY=

# Toggle behaviour. Users can still flip Auto/Off in the UI; this is the
# server-wide default for new users + sessions.
WEBSEARCH_DEFAULT_MODE=auto         # auto | off
WEBSEARCH_PRIMARY_PROVIDER=searxng  # searxng | jina | brave
WEBSEARCH_MAX_RESULTS=5
WEBSEARCH_PAGE_CONTENT_CHARS=4000
WEBSEARCH_TOTAL_CONTEXT_CHARS=12000
WEBSEARCH_CACHE_TTL_SECONDS=900
WEBSEARCH_CACHE_MAX_ENTRIES=500
WEBSEARCH_FETCH_TIMEOUT_MS=8000
WEBSEARCH_MAX_TOOL_CALLS_PER_TURN=75
WEBSEARCH_DENY_DOMAINS=
# Comma-separated hostnames added on top of the built-in adult deny list.

# Per-plan daily search quotas. Zero disables web search for that plan.
WEBSEARCH_DAILY_LIMIT_LITE=50
WEBSEARCH_DAILY_LIMIT_ESSENTIAL=200
WEBSEARCH_DAILY_LIMIT_PRO=500
