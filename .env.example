APP_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0

# Server-only managed model provider key. Never expose this to the browser.
CROFAI_API_KEY=
CROFAI_BASE_URL=https://crof.ai/v1

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_GOOGLE_ENABLED=false

# Access
# testing: every signed-in user gets TEST_PLAN_ID without a payment gateway.
# subscription: only users with an active row in subscriptions can chat.
ACCESS_MODE=testing
TEST_PLAN_ID=pro

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_UPLOAD_EXPIRES_SECONDS=300
R2_READ_EXPIRES_SECONDS=900
R2_MAX_IMAGE_BYTES=6291456

PLAN_HOBBY_PRICE_LABEL=
PLAN_HOBBY_DAILY_MESSAGES=150
PLAN_HOBBY_MONTHLY_IMAGES=200
PLAN_HOBBY_MAX_IMAGES_PER_MESSAGE=4

PLAN_PRO_PRICE_LABEL=
PLAN_PRO_DAILY_MESSAGES=600
PLAN_PRO_MONTHLY_IMAGES=1000
PLAN_PRO_MAX_IMAGES_PER_MESSAGE=4

PLAN_INTERMEDIATE_PRICE_LABEL=
PLAN_INTERMEDIATE_DAILY_MESSAGES=1500
PLAN_INTERMEDIATE_MONTHLY_IMAGES=2500
PLAN_INTERMEDIATE_MAX_IMAGES_PER_MESSAGE=4

PLAN_SCALE_PRICE_LABEL=
PLAN_SCALE_DAILY_MESSAGES=5000
PLAN_SCALE_MONTHLY_IMAGES=7500
PLAN_SCALE_MAX_IMAGES_PER_MESSAGE=6

PLAN_MAX_PRICE_LABEL=
PLAN_MAX_DAILY_MESSAGES=15000
PLAN_MAX_MONTHLY_IMAGES=20000
PLAN_MAX_MAX_IMAGES_PER_MESSAGE=8

# ─── Web search ────────────────────────────────────────────────────
# Primary: Jina Search Foundation (s.jina.ai) — one call returns search
# results + extracted page content for the top N URLs. JINA_API_KEY is
# REQUIRED for s.jina.ai (search). New keys include a 10M-token free
# trial, then pay-as-you-go. The reader endpoint r.jina.ai used by the
# `read_url` tool still works anonymously at ~20 RPM if no key is set.
JINA_API_KEY=
JINA_SEARCH_PROVIDER=google         # google | bing
JINA_SEARCH_ENGINE=direct           # direct (fast) | browser (JS-rendered)

# Fallback: Brave LLM Context API. $5/1k requests, $5/mo free credit.
BRAVE_SEARCH_API_KEY=

# Toggle behaviour. Users can still flip Auto/Off in the UI; this is the
# server-wide default for new users + sessions.
WEBSEARCH_DEFAULT_MODE=auto         # auto | off
WEBSEARCH_PRIMARY_PROVIDER=jina     # jina | brave
WEBSEARCH_MAX_RESULTS=5
WEBSEARCH_PAGE_CONTENT_CHARS=4000
WEBSEARCH_TOTAL_CONTEXT_CHARS=12000
WEBSEARCH_CACHE_TTL_SECONDS=900
WEBSEARCH_CACHE_MAX_ENTRIES=500
WEBSEARCH_FETCH_TIMEOUT_MS=8000
WEBSEARCH_MAX_TOOL_CALLS_PER_TURN=3
WEBSEARCH_DENY_DOMAINS=

# Per-plan daily search quotas. Zero disables web search for that plan.
WEBSEARCH_DAILY_LIMIT_HOBBY=50
WEBSEARCH_DAILY_LIMIT_PRO=200
WEBSEARCH_DAILY_LIMIT_INTERMEDIATE=500
WEBSEARCH_DAILY_LIMIT_SCALE=2000
WEBSEARCH_DAILY_LIMIT_MAX=5000
