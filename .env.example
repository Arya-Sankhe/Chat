APP_URL=http://localhost:3000
PORT=3000
HOST=0.0.0.0

# Server-only managed model provider key. Never expose this to the browser.
CROFAI_API_KEY=
CROFAI_BASE_URL=https://crof.ai/v1

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_GOOGLE_ENABLED=false

# Access
# testing: every signed-in user gets TEST_PLAN_ID without a payment gateway.
# subscription: only users with an active row in subscriptions can chat.
ACCESS_MODE=testing
TEST_PLAN_ID=pro

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_UPLOAD_EXPIRES_SECONDS=300
R2_READ_EXPIRES_SECONDS=900
R2_MAX_IMAGE_BYTES=6291456

# ─── Document tools ────────────────────────────────────────────────
DOCUMENTS_ENABLED=true
DOCUMENT_MAX_FILE_BYTES=31457280
DOCUMENT_MAX_FILES_PER_MESSAGE=5
DOCUMENT_MAX_TOTAL_BYTES_PER_MESSAGE=62914560
DOCUMENT_MAX_PDF_PAGES=100
DOCUMENT_MAX_DOCX_WORDS=80000
DOCUMENT_MAX_XLSX_SHEETS=25
DOCUMENT_MAX_XLSX_CELLS=250000
DOCUMENT_MAX_CSV_ROWS=100000
DOCUMENT_MAX_CSV_COLUMNS=100
DOCUMENT_MAX_EXTRACTED_CHARS=500000
DOCUMENT_CONTEXT_CHARS_PER_TURN=20000
DOCUMENT_MAX_TOOL_RESULT_CHARS=24000
DOCUMENT_MAX_TOOL_CALLS_PER_TURN=3
DOCUMENT_VISUAL_EMBED_MODEL=jina-embeddings-v5-omni-nano
DOCUMENT_VISUAL_PAGE_DPI=144
DOCUMENT_VISUAL_MAX_PAGES_PER_TOOL=40
DOCUMENT_VISUAL_MAX_IMAGE_INPUTS_PER_TURN=12
DOCUMENT_VISUAL_INLINE_IMAGES=true
DOCUMENT_VISUAL_INLINE_MAX_BYTES=2097152
DOCUMENT_VISUAL_INLINE_MAX_TOTAL_BYTES=10485760
DOCUMENT_WORKER_CONCURRENCY=1
DOCUMENT_JOB_TIMEOUT_MS=120000
DOCUMENT_TOOL_JOB_WAIT_MS=20000
DOCUMENT_UPLOAD_EXPIRES_SECONDS=900
DOCUMENT_PREVIEW_MAX_PAGES=2
DOCUMENT_PREVIEW_TTL_DAYS=30

PLAN_HOBBY_PRICE_LABEL=
PLAN_HOBBY_DAILY_MESSAGES=150
